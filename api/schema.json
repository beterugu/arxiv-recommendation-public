{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0.0",
  "paper": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "arxiv_id",
      "title",
      "abstract",
      "authors",
      "published",
      "updated",
      "categories",
      "abs_url",
      "headline",
      "one_liner",
      "key_points",
      "tags",
      "who_should_read",
      "application_ideas",
      "implementation_difficulty",
      "relevance_score",
      "domain_relevance",
      "practicality_score",
      "first_seen"
    ],
    "properties": {
      "arxiv_id": {
        "type": "string"
      },
      "title": {
        "type": "string"
      },
      "abstract": {
        "type": "string"
      },
      "authors": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "published": {
        "type": "string"
      },
      "updated": {
        "type": "string"
      },
      "categories": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "abs_url": {
        "type": "string"
      },
      "headline": {
        "type": "string"
      },
      "one_liner": {
        "type": "string"
      },
      "key_points": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "who_should_read": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "application_ideas": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "implementation_difficulty": {
        "type": "string"
      },
      "relevance_score": {
        "type": [
          "number",
          "null"
        ]
      },
      "domain_relevance": {
        "type": "object"
      },
      "practicality_score": {
        "type": [
          "number",
          "null"
        ]
      },
      "first_seen": {
        "type": "string"
      }
    }
  }
}
